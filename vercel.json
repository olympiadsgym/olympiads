{
  "version": 2,
  "builds": [
    {
      "src": "olympiads/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "olympiads/wsgi.py"
    }
  ],
  "buildCommand": "chmod +x build_files.sh && ./build_files.sh"
}
'@ | Set-Content vercel.json