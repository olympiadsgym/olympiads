{
  "version": 2,
  "builds": [
    {
      "src": "olympiads/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.12" }
    },
    {
      "src": "staticfiles/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "olympiads/wsgi.py"
    }
  ],
  "buildCommand": "chmod +x build_files.sh && ./build_files.sh"
}
